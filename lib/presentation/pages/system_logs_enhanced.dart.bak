        ),
      );
    }
  }

  String _generateSingleLogContent(Map<String, dynamic> log) {
    final content = StringBuffer();
    
    content.writeln('System Log Export - Single Log');
    content.writeln('Generated: ${DateTime.now().toString()}');
    content.writeln('=' * 50);
    content.writeln();
    
    content.writeln('Log ID: ${log['id']}');
    content.writeln('Timestamp: ${log['timestamp']}');
    content.writeln('Level: ${log['level']}');
    content.writeln('Category: ${log['category']}');
    content.writeln('Severity: ${log['severity']}');
    content.writeln('User: ${log['user']}');
    content.writeln('IP Address: ${log['ip']}');
    content.writeln('Resolved: ${log['resolved']}');
    content.writeln();
    content.writeln('Message:');
    content.writeln('${log['message']}');
    content.writeln();
    content.writeln('Details:');
    content.writeln('${log['details']}');
    content.writeln();
    content.writeln('=' * 50);
    content.writeln('End of Log');
    
    return content.toString();
  }

