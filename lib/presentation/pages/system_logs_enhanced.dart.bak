  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('יומני מערכת'),
        backgroundColor: Colors.purple,
        foregroundColor: Colors.white,
        actions: [
          IconButton(
            icon: _isDownloading
                ? const SizedBox(
                    width: 20,
                    height: 20,
                    child: CircularProgressIndicator(strokeWidth: 2),
                  )
                : const Icon(Icons.download),
            onPressed: _isDownloading ? null : _downloadLogs,
            tooltip: 'הורד יומנים',
          ),
          IconButton(
            icon: const Icon(Icons.calendar_today),
            onPressed: _isDownloading ? null : _showDailyDownloadDialog,
            tooltip: 'הורד קבצים יומיים',
          ),
          IconButton(
            icon: const Icon(Icons.analytics),
            onPressed: _showLogAnalysis,
            tooltip: 'ניתוח יומנים',
          ),
        ],
      ),
      body: Column(
        children: [
          _buildFilterSection(),
          _buildLogAnalysis(),
          _buildLogList(),
        ],
      ),
    );
  }

  Widget _buildFilterSection() {
    return Card(
      margin: const EdgeInsets.all(16),
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          children: [
            Row(
              children: [
                Expanded(
                  child: TextField(
                    controller: _searchController,
                    decoration: const InputDecoration(
                      hintText: 'חיפוש ביומנים...',
                      prefixIcon: Icon(Icons.search),
                      border: OutlineInputBorder(),
                    ),
                    onChanged: (value) {
                      setState(() {
                        _searchQuery = value;
                      });
                    },
                  ),
                ),
                const SizedBox(width: 16),
                Expanded(
                  child: DropdownButtonFormField<String>(
                    value: _selectedLogLevel,
                    decoration: const InputDecoration(
                      labelText: 'רמת יומן',
                      border: OutlineInputBorder(),
                    ),
                    items: const [
                      DropdownMenuItem(value: 'all', child: Text('הכל')),
                      DropdownMenuItem(value: 'ERROR', child: Text('שגיאות')),
                      DropdownMenuItem(value: 'WARNING', child: Text('אזהרות')),
                      DropdownMenuItem(value: 'INFO', child: Text('מידע')),
                    ],
                    onChanged: (value) {
                      setState(() {
                        _selectedLogLevel = value!;
                      });
                    },
                  ),
                ),
              ],
            ),
            const SizedBox(height: 16),
            Row(
              children: [
                Expanded(
                  child: DropdownButtonFormField<String>(
                    value: _selectedDateRange,
                    decoration: const InputDecoration(
                      labelText: 'טווח תאריכים',
                      border: OutlineInputBorder(),
                    ),
                    items: const [
                      DropdownMenuItem(value: 'today', child: Text('היום')),
                      DropdownMenuItem(value: 'week', child: Text('השבוע')),
                      DropdownMenuItem(value: 'month', child: Text('החודש')),
                      DropdownMenuItem(value: 'all', child: Text('הכל')),
                    ],
                    onChanged: (value) {
                      setState(() {
                        _selectedDateRange = value!;
                      });
                    },
                  ),
                ),
                const SizedBox(width: 16),
                ElevatedButton.icon(
                  onPressed: _refreshLogs,
                  icon: const Icon(Icons.refresh),
                  label: const Text('רענן'),
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildLogAnalysis() {
    final errorCount = _getFilteredLogs().where((log) => log['level'] == 'ERROR').length;
    final warningCount = _getFilteredLogs().where((log) => log['level'] == 'WARNING').length;
    final unresolvedCount = _getFilteredLogs().where((log) => !log['resolved']).length;
    final criticalCount = _getFilteredLogs().where((log) => log['severity'] == 'critical').length;

    return Card(
      margin: const EdgeInsets.symmetric(horizontal: 16),
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'ניתוח יומנים מקיף',
              style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 16),
            
            // Overall Statistics
            const Text(
              'סטטיסטיקות כלליות',
              style: TextStyle(fontSize: 16, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 8),
            Row(
              children: [
                Expanded(
                  child: _buildAnalysisCard('סה"כ יומנים', _logs.length, Colors.blue),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('לא פתורות', unresolvedCount, Colors.purple),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('קריטיות', criticalCount, Colors.red[800]!),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('חשובים', _logs.where((log) => log['severity'] == 'high').length, Colors.orange),
                ),
              ],
            ),
            
            const SizedBox(height: 16),
            
            // Log Levels
            const Text(
              'רמות יומנים',
              style: TextStyle(fontSize: 16, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 8),
            Row(
              children: [
                Expanded(
                  child: _buildAnalysisCard('שגיאות', errorCount, Colors.red),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('אזהרות', warningCount, Colors.orange),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('מידע', _logs.where((log) => log['level'] == 'INFO').length, Colors.green),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('אימות', _logs.where((log) => log['category'] == 'Authentication').length, Colors.indigo),
                ),
              ],
            ),
            
            const SizedBox(height: 16),
            
            // Activity Categories
            const Text(
              'קטגוריות פעילות',
              style: TextStyle(fontSize: 16, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 8),
            Row(
              children: [
                Expanded(
                  child: _buildAnalysisCard('תשלומים', _logs.where((log) => log['category'] == 'Payment').length, Colors.teal),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('תורים', _logs.where((log) => log['category'] == 'Appointment').length, Colors.cyan),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('מערכת', _logs.where((log) => log['category'] == 'System').length, Colors.grey),
                ),
                const SizedBox(width: 8),
                Expanded(
                  child: _buildAnalysisCard('אבטחה', _logs.where((log) => log['category'] == 'Security').length, Colors.deepOrange),
                ),
              ],
            ),
            if (criticalCount > 0 || unresolvedCount > 5) ...[
              const SizedBox(height: 16),
              Container(
                padding: const EdgeInsets.all(12),
                decoration: BoxDecoration(
                  color: Colors.red.withOpacity(0.1),
                  borderRadius: BorderRadius.circular(8),
                  border: Border.all(color: Colors.red.withOpacity(0.3)),
                ),
                child: Row(
                  children: [
                    const Icon(Icons.warning, color: Colors.red),
                    const SizedBox(width: 8),
                    Expanded(
                      child: Text(
                        criticalCount > 0 
                          ? 'נמצאו $criticalCount שגיאות קריטיות הדורשות טיפול מיידי!'
                          : 'נמצאו $unresolvedCount בעיות לא פתורות - מומלץ לבדוק',
                        style: const TextStyle(color: Colors.red, fontWeight: FontWeight.bold),
                      ),
                    ),
                  ],
                ),
              ),
            ],
          ],
        ),
      ),
    );
  }

  Widget _buildAnalysisCard(String title, int count, Color color) {
    return Container(
      padding: const EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: color.withOpacity(0.1),
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: color.withOpacity(0.3)),
      ),
      child: Column(
        children: [
          Text(
            count.toString(),
            style: TextStyle(
              fontSize: 24,
              fontWeight: FontWeight.bold,
              color: color,
            ),
          ),
          Text(
            title,
            style: TextStyle(
              fontSize: 12,
              color: color,
              fontWeight: FontWeight.w500,
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildLogList() {
    final filteredLogs = _getFilteredLogs();

    return Expanded(
      child: ListView.builder(
        padding: const EdgeInsets.symmetric(horizontal: 16),
        itemCount: filteredLogs.length,
        itemBuilder: (context, index) {
          final log = filteredLogs[index];
          return _buildLogCard(log);
        },
      ),
    );
  }

  Widget _buildLogCard(Map<String, dynamic> log) {
    Color levelColor;
    IconData levelIcon;
    
    switch (log['level']) {
      case 'ERROR':
        levelColor = Colors.red;
        levelIcon = Icons.error;
        break;
      case 'WARNING':
        levelColor = Colors.orange;
        levelIcon = Icons.warning;
        break;
      case 'INFO':
        levelColor = Colors.blue;
        levelIcon = Icons.info;
        break;
      default:
        levelColor = Colors.grey;
        levelIcon = Icons.info;
    }

    return Card(
      margin: const EdgeInsets.only(bottom: 12),
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                Icon(levelIcon, color: levelColor, size: 20),
                const SizedBox(width: 8),
                Text(
                  log['level'],
                  style: TextStyle(
                    color: levelColor,
                    fontWeight: FontWeight.bold,
                    fontSize: 12,
                  ),
                ),
                const SizedBox(width: 16),
                Expanded(
                  child: Text(
                    log['timestamp'],
                    style: const TextStyle(
                      color: Colors.grey,
                      fontSize: 12,
                    ),
                  ),
                ),
                Container(
                  padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                  decoration: BoxDecoration(
                    color: log['resolved'] ? Colors.green.withOpacity(0.2) : Colors.red.withOpacity(0.2),
                    borderRadius: BorderRadius.circular(12),
                  ),
                  child: Text(
                    log['resolved'] ? 'פתור' : 'לא פתור',
                    style: TextStyle(
                      color: log['resolved'] ? Colors.green : Colors.red,
                      fontWeight: FontWeight.bold,
                      fontSize: 10,
                    ),
                  ),
                ),
              ],
            ),
            const SizedBox(height: 8),
            Text(
              log['message'],
              style: const TextStyle(
                fontWeight: FontWeight.bold,
                fontSize: 14,
              ),
            ),
            const SizedBox(height: 4),
            Text(
              'קטגוריה: ${log['category']} | חומרה: ${log['severity']}',
              style: const TextStyle(
                color: Colors.grey,
                fontSize: 12,
              ),
            ),
            if (log['details'].isNotEmpty) ...[
              const SizedBox(height: 8),
              Text(
                'פרטים: ${log['details']}',
                style: const TextStyle(fontSize: 12),
              ),
            ],
            const SizedBox(height: 8),
            Row(
              children: [
                Text(
                  'משתמש: ${log['user']}',
                  style: const TextStyle(fontSize: 11, color: Colors.grey),
                ),
                const SizedBox(width: 16),
                Text(
                  'IP: ${log['ip']}',
                  style: const TextStyle(fontSize: 11, color: Colors.grey),
                ),
              ],
            ),
            const SizedBox(height: 12),
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceEvenly,
              children: [
                _buildLogActionButton('פרטים', Icons.visibility, Colors.blue, () => _viewLogDetails(log)),
                _buildLogActionButton('סמן כפתור', Icons.check_circle, Colors.green, () => _markAsResolved(log)),
                _buildLogActionButton('הורד', Icons.download, Colors.orange, () => _downloadSingleLog(log)),
              ],
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildLogActionButton(String label, IconData icon, Color color, VoidCallback onPressed) {
    return ElevatedButton.icon(
      onPressed: onPressed,
      icon: Icon(icon, size: 16),
      label: Text(label),
      style: ElevatedButton.styleFrom(
        backgroundColor: color,
        foregroundColor: Colors.white,
        padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
      ),
    );
  }

  List<Map<String, dynamic>> _getFilteredLogs() {
    return _logs.where((log) {
      final matchesSearch = _searchQuery.isEmpty ||
          log['message'].toLowerCase().contains(_searchQuery.toLowerCase()) ||
          log['category'].toLowerCase().contains(_searchQuery.toLowerCase()) ||
          log['details'].toLowerCase().contains(_searchQuery.toLowerCase());
      
      final matchesLevel = _selectedLogLevel == 'all' || log['level'] == _selectedLogLevel;
      
      return matchesSearch && matchesLevel;
    }).toList();
  }

