    );
  }

  // Download daily log files
  void _downloadDailyLogs() async {
    if (_isDownloading) return;
    
    setState(() {
      _isDownloading = true;
    });

    try {
      // Show processing dialog
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) => AlertDialog(
          content: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const CircularProgressIndicator(),
              const SizedBox(height: 16),
              Text('יוצר קבצי יומנים יומיים...'),
            ],
          ),
        ),
      );

      await Future.delayed(const Duration(seconds: 2));

      // Group logs by date
      Map<String, List<Map<String, dynamic>>> dailyLogs = {};
      for (var log in _logs) {
        String date = log['timestamp'].toString().split(' ')[0]; // Extract date part
        if (!dailyLogs.containsKey(date)) {
          dailyLogs[date] = [];
        }
        dailyLogs[date]!.add(log);
      }

      // Create and download files for each day
      int filesCreated = 0;
      for (String date in dailyLogs.keys) {
        List<Map<String, dynamic>> dayLogs = dailyLogs[date]!;
        
        // Generate content for the day
        String csvContent = _generateDailyCSVContent(dayLogs, date);
        String jsonContent = _generateDailyJSONContent(dayLogs, date);
        String txtContent = _generateDailyTXTContent(dayLogs, date);
        
        // Download CSV
        await _downloadDailyFile('${date}_system_logs.csv', csvContent);
        await Future.delayed(const Duration(milliseconds: 500));
        
        // Download JSON
        await _downloadDailyFile('${date}_system_logs.json', jsonContent);
        await Future.delayed(const Duration(milliseconds: 500));
        
        // Download TXT
        await _downloadDailyFile('${date}_system_logs.txt', txtContent);
        await Future.delayed(const Duration(milliseconds: 500));
        
        filesCreated++;
      }

      // Close processing dialog
      Navigator.of(context).pop();

      // Show success dialog
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: const Text('הורדת קבצים יומיים הושלמה!'),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text('נוצרו ${filesCreated} ימים של קבצים'),
              Text('סה"כ קבצים: ${filesCreated * 3} (CSV, JSON, TXT לכל יום)'),
              const SizedBox(height: 8),
              const Text('כל הקבצים נשמרו בתיקיית ההורדות שלך', 
                style: TextStyle(fontSize: 12, color: Colors.grey)),
            ],
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('אישור'),
            ),
          ],
        ),
      );

    } catch (e) {
      // Close any open dialogs
      Navigator.of(context).pop();
      
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('שגיאה בהורדת קבצים יומיים: $e')),
      );
    } finally {
      setState(() {
        _isDownloading = false;
      });
    }
  }

  // Helper method to download individual daily files
  Future<void> _downloadDailyFile(String fileName, String content) async {
    // Use clipboard for all platforms
    await Clipboard.setData(ClipboardData(text: content));
  }

  // Generate daily CSV content
  String _generateDailyCSVContent(List<Map<String, dynamic>> dayLogs, String date) {
    StringBuffer buffer = StringBuffer();
    
    // Add BOM for proper UTF-8 encoding in Excel
    buffer.write('\uFEFF');
    
    // Improved headers with clear, professional titles
    final headers = [
      'Log ID',
      'Date',
      'Time',
      'Log Level',
      'Category',
      'Event Description',
      'Detailed Information',
      'Severity Level',
      'Status',
      'User Account',
      'IP Address',
      'Session ID',
      'Device Info',
      'Location',
      'Duration (ms)',
      'Error Code'
    ];
    
    buffer.writeln(headers.map((h) => '"$h"').join(','));
    
    for (var log in dayLogs) {
      String timestamp = log['timestamp'].toString();
      String time = timestamp.split(' ')[1]; // Extract time part
      
      final row = [
        log['id'] ?? '',
        date,
        time,
        log['level'] ?? '',
        log['category'] ?? '',
        '"${(log['message'] ?? '').replaceAll('"', '""')}"',
        '"${(log['details'] ?? '').replaceAll('"', '""')}"',
        log['severity'] ?? '',
        (log['resolved'] == true) ? 'Resolved' : 'Pending',
        log['user'] ?? '',
        log['ip'] ?? '',
        log['sessionId'] ?? 'N/A',
        log['deviceInfo'] ?? 'N/A',
        log['location'] ?? 'N/A',
        log['duration'] ?? 'N/A',
        log['errorCode'] ?? 'N/A'
      ];
      
      buffer.writeln(row.join(','));
    }
    
    return buffer.toString();
  }

  // Generate daily JSON content
  String _generateDailyJSONContent(List<Map<String, dynamic>> dayLogs, String date) {
    Map<String, dynamic> dailyData = {
      'date': date,
      'total_logs': dayLogs.length,
      'generated_at': DateTime.now().toIso8601String(),
      'logs': dayLogs,
    };
    
    return const JsonEncoder.withIndent('  ').convert(dailyData);
  }

  // Generate daily TXT content
  String _generateDailyTXTContent(List<Map<String, dynamic>> dayLogs, String date) {
    StringBuffer buffer = StringBuffer();
    buffer.writeln('=== יומני מערכת - $date ===');
    buffer.writeln('נוצר ב: ${DateTime.now().toString()}');
    buffer.writeln('סה"כ יומנים: ${dayLogs.length}');
    buffer.writeln('');
    
    for (var log in dayLogs) {
      buffer.writeln('--- יומן #${log['id']} ---');
      buffer.writeln('תאריך: ${log['timestamp']}');
      buffer.writeln('רמה: ${log['level']}');
      buffer.writeln('קטגוריה: ${log['category']}');
      buffer.writeln('הודעה: ${log['message']}');
      buffer.writeln('פרטים: ${log['details']}');
      buffer.writeln('חומרה: ${log['severity']}');
      buffer.writeln('נפתר: ${log['resolved'] ? 'כן' : 'לא'}');
      buffer.writeln('משתמש: ${log['user']}');
      buffer.writeln('IP: ${log['ip']}');
      buffer.writeln('');
    }
    
    return buffer.toString();
  }
}
