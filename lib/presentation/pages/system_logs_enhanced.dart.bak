  void _downloadLogsAsFile(String format) async {
    setState(() {
      _isDownloading = true;
    });
    
    try {
      final filteredLogs = _getFilteredLogs();
      final fileName = 'system_logs_${DateTime.now().millisecondsSinceEpoch}.$format';
      
      // Show detailed loading dialog
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) => AlertDialog(
          title: const Text('מוריד יומנים'),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const CircularProgressIndicator(),
              const SizedBox(height: 16),
              Text('מעבד ${filteredLogs.length} יומנים...'),
              const SizedBox(height: 8),
              Text('פורמט: $format'),
              const SizedBox(height: 8),
              const Text('אנא המתן...'),
            ],
          ),
        ),
      );

      // Simulate processing time to show progress
      await Future.delayed(const Duration(milliseconds: 500));

      String fileContent = '';
      String mimeType = '';

      // Update loading dialog
      Navigator.pop(context);
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) => AlertDialog(
          title: const Text('יוצר קובץ'),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const CircularProgressIndicator(),
              const SizedBox(height: 16),
              const Text('יוצר תוכן הקובץ...'),
            ],
          ),
        ),
      );

      switch (format.toLowerCase()) {
        case 'csv':
          fileContent = _generateCSVContent(filteredLogs);
          mimeType = 'text/csv';
          break;
        case 'json':
          fileContent = _generateJSONContent(filteredLogs);
          mimeType = 'application/json';
          break;
        case 'txt':
          fileContent = _generateTXTContent(filteredLogs);
          mimeType = 'text/plain';
          break;
        default:
          throw Exception('Unsupported format: $format');
      }

      // Update loading dialog
      Navigator.pop(context);
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) => AlertDialog(
          title: const Text('מוריד קובץ'),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const CircularProgressIndicator(),
              const SizedBox(height: 16),
              Text('מוריד $fileName...'),
              const SizedBox(height: 8),
              const Text('הקובץ יופיע בהורדות שלך'),
            ],
          ),
        ),
      );

      // Create blob and trigger download for web/desktop
      final bytes = utf8.encode(fileContent);
      
      // Use clipboard for all platforms (works on both web and desktop)
      await Clipboard.setData(ClipboardData(text: fileContent));
      ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('תוכן היומנים הועתק ללוח. נא לשמור את הקובץ: $fileName'),
            duration: const Duration(seconds: 5),
            action: SnackBarAction(
              label: 'אישור',
              onPressed: () {},
            ),
          ),
        );

      // Simulate download time
      await Future.delayed(const Duration(milliseconds: 1000));

      // Close loading dialog
      Navigator.pop(context);

      setState(() {
        _isDownloading = false;
      });

      // Show success dialog with more details
      // Capture variables for use in dialog builder
      final finalFileName = fileName;
      final finalFileContent = fileContent;
      final finalFilteredLogs = filteredLogs;
      final finalFormat = format;
      
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: Row(
            children: [
              const Icon(Icons.check_circle, color: Colors.green),
              const SizedBox(width: 8),
              const Text('הורדה הושלמה!'),
            ],
          ),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              const Text('הקובץ הורד בהצלחה!', style: TextStyle(fontWeight: FontWeight.bold)),
              const SizedBox(height: 16),
              Container(
                padding: const EdgeInsets.all(12),
                decoration: BoxDecoration(
                  color: Colors.grey[100],
                  borderRadius: BorderRadius.circular(8),
                ),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text('📁 שם קובץ: $finalFileName'),
                    const SizedBox(height: 4),
                    Text('📊 פורמט: ${finalFormat.toUpperCase()}'),
                    const SizedBox(height: 4),
                    Text('📏 גודל: ${(finalFileContent.length / 1024).toStringAsFixed(1)} KB'),
                    const SizedBox(height: 4),
                    Text('📋 מספר רשומות: ${finalFilteredLogs.length}'),
                  ],
                ),
              ),
              const SizedBox(height: 16),
              const Row(
                children: [
                  Icon(Icons.folder, size: 16, color: Colors.blue),
                  SizedBox(width: 4),
                  Text('הקובץ נשמר בתיקיית ההורדות שלך'),
                ],
              ),
            ],
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(context),
              child: const Text('סגור'),
            ),
            ElevatedButton.icon(
              onPressed: () {
                Navigator.pop(context);
                _showDownloadInstructions();
              },
              icon: const Icon(Icons.help),
              label: const Text('הוראות'),
            ),
          ],
        ),
      );

    } catch (e) {
      // Close loading dialog if open
      Navigator.pop(context);
      
      setState(() {
        _isDownloading = false;
      });
      
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: const Row(
            children: [
              Icon(Icons.error, color: Colors.red),
              SizedBox(width: 8),
              Text('שגיאה בהורדה'),
            ],
          ),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const Text('אירעה שגיאה במהלך ההורדה:'),
              const SizedBox(height: 8),
              Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: Colors.red[50],
                  borderRadius: BorderRadius.circular(4),
                ),
                child: Text(
                  e.toString(),
                  style: const TextStyle(fontSize: 12, color: Colors.red),
                ),
              ),
            ],
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(context),
              child: const Text('סגור'),
            ),
            ElevatedButton(
              onPressed: () {
                Navigator.pop(context);
                _downloadLogsAsFile(format); // Retry
              },
              child: const Text('נסה שוב'),
            ),
          ],
        ),
      );
    }
  }

