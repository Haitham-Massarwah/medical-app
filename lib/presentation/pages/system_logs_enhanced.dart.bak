  String _generateCSVContent(List<Map<String, dynamic>> logs) {
    if (logs.isEmpty) return '';
    
    // Improved headers with clear, professional titles
    final headers = [
      'Log ID',
      'Date & Time',
      'Log Level',
      'Category',
      'Event Description',
      'Detailed Information',
      'Severity Level',
      'User Account',
      'IP Address',
      'Status',
      'Session ID',
      'Device Info',
      'Location',
      'Duration (ms)',
      'Error Code',
      'Additional Data'
    ];
    
    final csvContent = StringBuffer();
    
    // Add BOM for proper UTF-8 encoding in Excel
    csvContent.write('\uFEFF');
    
    // Add headers with proper CSV escaping
    csvContent.writeln(headers.map((h) => '"$h"').join(','));
    
    // Add data rows with improved formatting
    for (final log in logs) {
      final row = [
        log['id'] ?? '',
        log['timestamp'] ?? '',
        log['level'] ?? '',
        log['category'] ?? '',
        '"${(log['message'] ?? '').replaceAll('"', '""')}"',
        '"${(log['details'] ?? '').replaceAll('"', '""')}"',
        log['severity'] ?? '',
        log['user'] ?? '',
        log['ip'] ?? '',
        (log['resolved'] == true) ? 'Resolved' : 'Pending',
        log['sessionId'] ?? 'N/A',
        log['deviceInfo'] ?? 'N/A',
        log['location'] ?? 'N/A',
        log['duration'] ?? 'N/A',
        log['errorCode'] ?? 'N/A',
        '"${(log['additionalData'] ?? '').replaceAll('"', '""')}"'
      ];
      csvContent.writeln(row.join(','));
    }
    
    return csvContent.toString();
  }

  String _generateJSONContent(List<Map<String, dynamic>> logs) {
    return const JsonEncoder.withIndent('  ').convert({
      'exported_at': DateTime.now().toIso8601String(),
      'total_logs': logs.length,
      'logs': logs,
    });
  }

  String _generateTXTContent(List<Map<String, dynamic>> logs) {
    if (logs.isEmpty) return 'No logs found.';
    
    final txtContent = StringBuffer();
    txtContent.writeln('System Logs Export');
    txtContent.writeln('Generated: ${DateTime.now().toString()}');
    txtContent.writeln('Total Logs: ${logs.length}');
    txtContent.writeln('=' * 50);
    txtContent.writeln();
    
    for (final log in logs) {
      txtContent.writeln('ID: ${log['id']}');
      txtContent.writeln('Timestamp: ${log['timestamp']}');
      txtContent.writeln('Level: ${log['level']}');
      txtContent.writeln('Category: ${log['category']}');
      txtContent.writeln('Message: ${log['message']}');
      txtContent.writeln('Details: ${log['details']}');
      txtContent.writeln('Severity: ${log['severity']}');
      txtContent.writeln('User: ${log['user']}');
      txtContent.writeln('IP: ${log['ip']}');
      txtContent.writeln('Resolved: ${log['resolved']}');
      txtContent.writeln('-' * 30);
      txtContent.writeln();
    }
    
    return txtContent.toString();
  }


  void _downloadSingleLog(Map<String, dynamic> log) async {
    try {
      final fileName = 'log_${log['id']}_${DateTime.now().millisecondsSinceEpoch}.txt';
      
      // Show loading dialog
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) => AlertDialog(
          title: const Text('מוריד יומן'),
          content: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const CircularProgressIndicator(),
              const SizedBox(height: 16),
              Text('מוריד יומן #${log['id']}...'),
            ],
          ),
        ),
      );

      // Generate single log content
      final logContent = _generateSingleLogContent(log);

      // Create blob and trigger download for web/desktop
      final bytes = utf8.encode(logContent);
      
      // Use clipboard for all platforms
      await Clipboard.setData(ClipboardData(text: logContent));
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('תוכן היומן הועתק ללוח. נא לשמור את הקובץ: $fileName'),
          duration: const Duration(seconds: 5),
        ),
      );

      // Simulate download time
      await Future.delayed(const Duration(milliseconds: 500));

      // Close loading dialog
      Navigator.pop(context);

      // Show success dialog
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: Row(
            children: [
              const Icon(Icons.check_circle, color: Colors.green),
