{
  "name": "medical-appointment-backend",
  "version": "1.0.0",
  "description": "Backend API for Medical Appointment System with multi-tenant support",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:watch": "jest --watch",
    "test:db": "node test-db-connection.js",
    "lint": "eslint -c .eslintrc.cjs src tests --ext .ts --max-warnings 0",
    "db:auto-fix-user": "node scripts/auto-fix-db-user.cjs",
    "clinic:secrets": "node scripts/clinic-generate-secrets.cjs",
    "clinic:init-env": "node scripts/clinic-init-production-env.cjs",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "upgrade:local": "npm ci && npm run build && npm run migrate",
    "update:check": "node scripts/check-update.cjs",
    "upgrade:auto:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\clinic-auto-upgrade.ps1",
    "upgrade:auto:linux": "bash ./scripts/clinic-auto-upgrade.sh"
  },
  "keywords": [
    "medical",
    "appointment",
    "healthcare",
    "rest-api",
    "multi-tenant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "agenda": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.13.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "simple-update-notifier": "^2.0.0",
    "stripe": "^14.9.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
